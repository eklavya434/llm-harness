# Gemini API Key (Required for live evaluations, set via HF secrets in production)
GEMINI_API_KEY=your_gemini_api_key_here

# Judge Settings (GEMINI or OLLAMA)
JUDGE_PROVIDER=GEMINI

# Ollama Fallback Settings (Local dev only)
OLLAMA_API_BASE=http://localhost:11434
OLLAMA_MODEL=llama3

# SQLite database file path (HF Space must write to /tmp)
DATABASE_PATH=/tmp/eval.db

# CORS configuration
ALLOWED_ORIGIN=http://localhost:3000
